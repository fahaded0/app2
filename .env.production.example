# Production environment template for docker-compose.production.yml.
#
# Copy this file to .env.production and populate the required values:
#
#   Copy-Item .env.production.example .env.production
#
# Never commit .env.production. This example intentionally contains no secret.
#
# Package 3 exposes only the frontend reverse-proxy endpoint on host loopback.
# Package 5 replaces this temporary HTTP binding with the TLS edge proxy.
# Package 4 replaces the transitional unauthenticated MongoDB configuration
# with keyfile authentication and a scoped application database user.

# Compose identity and locally built image tag
COMPOSE_PROJECT_NAME=app2-production
APP_IMAGE_TAG=local

# Temporary Package 3 loopback ingress
APP_BIND_ADDRESS=127.0.0.1
APP_HTTP_PORT=8080

# Backend runtime configuration
DB_NAME=medstock
MONGO_URL=mongodb://mongo:27017/?replicaSet=rs0

# REQUIRED: generate a cryptographically random value of at least 32 characters.
# Example generation in PowerShell:
#   [Convert]::ToBase64String(
#       [Security.Cryptography.RandomNumberGenerator]::GetBytes(48)
#   )
JWT_SECRET=

# Production safety settings
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
SEED_DATA_ENABLED=false

# Leave blank for same-origin browser access through the frontend proxy.
# When populated in production, every origin must use HTTPS and must not be
# localhost, a loopback address, a wildcard, or contain a path.
CORS_ALLOWED_ORIGINS=

# Optional email configuration
APP_URL=
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# Bounded Docker json-file logging
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
