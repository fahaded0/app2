# Production environment template for docker-compose.production.yml.
#
# Create the ignored MongoDB secret files:
#
#   powershell -NoProfile -ExecutionPolicy Bypass `
#     -File .\deploy\mongo\prepare-secrets.ps1
#
# Copy this template:
#
#   Copy-Item .env.production.example .env.production
#
# Never commit .env.production or generated *.key or *.pem files.
# This example intentionally contains no secret value.

# Compose identity and locally built image tag
COMPOSE_PROJECT_NAME=app2-production
APP_IMAGE_TAG=local

# TLS edge ingress.
# Keep 127.0.0.1 for local validation. For internal deployment, replace it
# with the specifically approved server interface address.
HTTPS_BIND_ADDRESS=127.0.0.1
HTTPS_PORT=443

# Approved PEM certificate chain and unencrypted PEM private key.
# The certificate must cover the final internal DNS hostname.
TLS_CERTIFICATE_FILE=./deploy/tls/secrets/tls-certificate.pem
TLS_PRIVATE_KEY_FILE=./deploy/tls/secrets/tls-private.key
# MongoDB application database
DB_NAME=medstock

# Explicit persistent-volume names.
# Do not rename these after data has been written unless migration is planned.
MONGO_DATA_VOLUME_NAME=app2-production-mongo-data
MONGO_CONFIG_VOLUME_NAME=app2-production-mongo-config

# MongoDB file-backed secrets.
# The default generator creates all five files under deploy/mongo/secrets/.
MONGO_ROOT_USERNAME_FILE=./deploy/mongo/secrets/mongo-root-username.key
MONGO_ROOT_PASSWORD_FILE=./deploy/mongo/secrets/mongo-root-password.key
MONGO_APP_USERNAME_FILE=./deploy/mongo/secrets/mongo-app-username.key
MONGO_APP_PASSWORD_FILE=./deploy/mongo/secrets/mongo-app-password.key
MONGO_REPLICA_SET_KEY_FILE=./deploy/mongo/secrets/mongo-keyfile.key

# The backend constructs MONGO_URL internally from the scoped application
# username/password files. Do not place a MongoDB password in this env file.

# REQUIRED: generate a cryptographically random value of at least 32 characters.
# Example:
#   [Convert]::ToBase64String(
#       [Security.Cryptography.RandomNumberGenerator]::GetBytes(48)
#   )
JWT_SECRET=

# Production safety settings
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
SEED_DATA_ENABLED=false

# Leave blank for same-origin browser access through the frontend proxy.
CORS_ALLOWED_ORIGINS=

# Public application URL and optional email configuration.
# APP_URL must use the approved HTTPS hostname covered by the certificate.
APP_URL=
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# Bounded Docker json-file logging
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
