# Docker build context excludes for the frontend production image.
# package.json, yarn.lock, public/, src/, craco.config.js, and
# tailwind.config.js are intentionally NOT excluded — they are required by
# the builder stage.

node_modules/
build/
coverage/

.env
.env.*

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

.git
.git/
.gitignore
.gitattributes
.gitconfig

.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
