# Copy this file to .env and fill in real values for local development.
# Never commit .env or any file containing real credentials.

# Runtime environment: development | production
APP_ENV=development

# MongoDB connection string
MONGO_URL=mongodb://localhost:27017

# MongoDB database name
DB_NAME=medstock

# Secret key for JWT signing — use a long random string in production
JWT_SECRET=change-me-use-a-long-random-secret

# Admin account created by seeder
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password

# Set to true to run the seed data loader on startup (development only)
# Default: false — seeding is skipped in production
SEED_DATA_ENABLED=false

# Cookie security settings
# Requires HTTPS. Set to false only for local HTTP development.
COOKIE_SECURE=true
# One of: lax | strict | none
COOKIE_SAMESITE=lax

# Comma-separated list of allowed CORS origins
# Example: https://app.example.com,https://staging.example.com
# Leave empty to disallow all cross-origin requests
CORS_ALLOWED_ORIGINS=http://localhost:3000

# URL the frontend uses to reach the backend API
REACT_APP_BACKEND_URL=http://localhost:8000

# Resend email API key (leave blank to disable email sending)
RESEND_API_KEY=re_placeholder_key

# Sender address used for outbound emails
SENDER_EMAIL=noreply@example.com

# Public application URL (used in email links)
APP_URL=http://localhost:3000

# Set to true in CI to fail test collection when REACT_APP_BACKEND_URL is missing
# Default: false — integration tests are silently skipped locally
CI_INTEGRATION_TESTS_REQUIRED=false
