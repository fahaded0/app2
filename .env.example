# Copy this file to .env and fill in real values for local development.
# Never commit .env or any file containing real credentials.

# Runtime environment.
# Accepted values: development, test, staging, production
# Default: development
# Production-only restrictions (HTTPS CORS, no seeding, COOKIE_SECURE=true)
# are enforced only when APP_ENV=production.
APP_ENV=development

# MongoDB connection string.
# Must begin with mongodb:// or mongodb+srv://
MONGO_URL=mongodb://localhost:27017

# MongoDB database name
DB_NAME=medstock

# Secret key for JWT signing.
# Minimum 32 characters. Use a long random string in production.
JWT_SECRET=change-me-use-a-long-random-secret

# Admin account created by seeder (required only when SEED_DATA_ENABLED=true)
ADMIN_EMAIL=admin@example.com
# Minimum 12 characters. Must not equal this placeholder value.
ADMIN_PASSWORD=change-me-strong-password

# Set to true to run the seed data loader on startup (development only).
# Default: false — seeding is always rejected in production.
SEED_DATA_ENABLED=false

# Cookie security settings.
# COOKIE_SECURE: requires HTTPS. Set to false only for local HTTP development.
# Default: true
# Accepted boolean values: true, false, 1, 0, yes, no
COOKIE_SECURE=true
# COOKIE_SAMESITE: one of lax, strict, none (default: lax).
# SameSite=none requires COOKIE_SECURE=true.
COOKIE_SAMESITE=lax

# Comma-separated list of allowed CORS origins.
# Each origin must use http or https, include a hostname, and have no path,
# query string, fragment, or embedded credentials.
# Duplicate origins are silently removed (first occurrence kept).
# In production: all origins must use HTTPS; localhost and loopback
# addresses (127.x.x.x, [::1]) are rejected.
# Leave empty to disallow all cross-origin requests.
# Example: https://app.example.com,https://staging.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# URL the frontend uses to reach the backend API
REACT_APP_BACKEND_URL=http://localhost:8000

# Resend email API key (leave blank to disable email sending)
RESEND_API_KEY=re_placeholder_key

# Sender address used for outbound emails
SENDER_EMAIL=noreply@example.com

# Public application URL (used in email links)
APP_URL=http://localhost:3000

# Set to true in CI to abort pytest when REACT_APP_BACKEND_URL is missing.
# Default: false — integration tests are skipped locally; unit tests always run.
# Accepted values (case-insensitive): true, false, 1, 0, yes, no
CI_INTEGRATION_TESTS_REQUIRED=false
