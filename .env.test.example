# .env.test.example — template for the disposable integration-test environment.
#
# This file is for LOCAL DISPOSABLE TESTING ONLY.
# It must NEVER be reused in staging or production.
# Values here are intentionally obvious test placeholders; they carry no
# real credentials and provide no security.
#
# Usage:
#   cp .env.test.example .env.test       # Linux/macOS
#   Copy-Item .env.test.example .env.test   # Windows PowerShell
#
# .env.test is ignored by Git (see .gitignore).
# Never commit .env.test.

# ── Backend runtime ───────────────────────────────────────────────────────────
APP_ENV=test
MONGO_URL=mongodb://mongo:27017/?replicaSet=rs0
DB_NAME=medstock_test

# Minimum 32 characters; test-only placeholder — change if running outside Docker.
JWT_SECRET=test-jwt-secret-for-local-disposable-use-only-32ch

# ── Seed credentials ──────────────────────────────────────────────────────────
# ADMIN_PASSWORD must be at least 12 characters and must not equal the
# .env.example placeholder.
ADMIN_EMAIL=admin@medstock.sa
ADMIN_PASSWORD=TestAdmin@12345
SEED_DATA_ENABLED=true

# ── Cookie / CORS ─────────────────────────────────────────────────────────────
# COOKIE_SECURE=false is acceptable here because this is a local HTTP test
# environment. Never use false in staging or production.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Test runner ───────────────────────────────────────────────────────────────
REACT_APP_BACKEND_URL=http://backend:8000
CI_INTEGRATION_TESTS_REQUIRED=true
TEST_ADMIN_EMAIL=admin@medstock.sa
TEST_ADMIN_PASSWORD=TestAdmin@12345
